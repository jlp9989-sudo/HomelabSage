# HomelabSage — Variables de entorno
# Copia este archivo a `.env` (gitignored).

# LLM (solo si provider != ollama)
LLM_API_KEY=

# Home Assistant — Long-Lived Access Token (Profile → Security)
HA_TOKEN=

# Notion — Integration API key + DB ID
NOTION_API_KEY=
NOTION_DB_INFRA_UPDATES=

# Telegram bot push
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Heartbeat push (Uptime Kuma push monitor / Healthchecks.io)
HEARTBEAT_URL=

# Web UI HTTP Basic Auth password (when web.auth.enabled: true)
HOMELABSAGE_PASSWORD=

# GitHub API token (optional but strongly recommended).
# Without a token, the GitHub API allows only 60 requests/hour per IP — easy
# to hit if you watch more than a handful of containers. With a token, the
# limit rises to 5,000 requests/hour, which comfortably covers any homelab.
# Create a fine-grained personal access token with read-only "Contents" access
# on public repositories (no other scopes needed):
#   https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=
