# HomelabSage — Variables de entorno
# Copia este archivo a `.env` (gitignored).

# LLM (solo si provider != ollama)
LLM_API_KEY=

# Home Assistant — Long-Lived Access Token (Profile → Security)
HA_TOKEN=

# Notion — Integration API key + DB ID
NOTION_API_KEY=
NOTION_DB_INFRA_UPDATES=

# Telegram bot push
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Heartbeat push (Uptime Kuma push monitor / Healthchecks.io)
HEARTBEAT_URL=

# Web UI HTTP Basic Auth password (when web.auth.enabled: true)
HOMELABSAGE_PASSWORD=

# GitHub token — bumps API rate-limit from 60/h to 5000/h.
# Create a fine-grained token with public-repo read access only.
GITHUB_TOKEN=
